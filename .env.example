ANTHROPIC_API_KEY=sk-ant-...
LINEAR_API_KEY=lin_api_...
LINEAR_WEBHOOK_SECRET=your-linear-webhook-secret
LINEAR_TEAM_ID=your-team-uuid

# GitHub — required for DeveloperAgent to push branches and open PRs
GITHUB_TOKEN=ghp_...

# Telegram — set to enable the Telegram bot integration
TELEGRAM_BOT_TOKEN=123456789:AAF...

LOG_LEVEL=INFO

# Langfuse tracing (optional — traces are no-op if unset)
# Self-hosted: set LANGFUSE_HOST to your VPS URL
# Cloud: use https://cloud.langfuse.com
LANGFUSE_HOST=https://langfuse.yourdomain.com
LANGFUSE_PUBLIC_KEY=pk-lf-...
LANGFUSE_SECRET_KEY=sk-lf-...

# Alternative: any OTLP-compatible backend (overrides Langfuse)
# OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318

# ─── Production / Docker Compose ─────────────────────────────────────────────
# Domains (used by Caddy for HTTPS and Langfuse's NEXTAUTH_URL)
CONDUCTOR_DOMAIN=conductor.yourdomain.com
LANGFUSE_DOMAIN=langfuse.yourdomain.com

# Langfuse Postgres password (choose a strong random string)
LANGFUSE_DB_PASSWORD=changeme

# Langfuse auth secrets (generate with: openssl rand -hex 32)
LANGFUSE_NEXTAUTH_SECRET=changeme
LANGFUSE_SALT=changeme
